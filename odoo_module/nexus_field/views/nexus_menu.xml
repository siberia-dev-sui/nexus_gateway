<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menú principal -->
    <menuitem
        id="menu_nexus_root"
        name="NEXUS Field"
        sequence="50"
        web_icon="nexus_field,static/src/img/icon.png"/>

    <menuitem
        id="menu_nexus_map"
        name="Mapa en Tiempo Real"
        parent="menu_nexus_root"
        action="action_nexus_map"
        sequence="1"/>

    <menuitem
        id="menu_nexus_config"
        name="Configuración"
        parent="menu_nexus_root"
        action="action_nexus_config"
        sequence="99"/>

    <!-- Acción del mapa -->
    <record id="action_nexus_map" model="ir.actions.client">
        <field name="name">Vendedores en Campo</field>
        <field name="tag">nexus_map</field>
    </record>

    <!-- Acción de configuración -->
    <record id="action_nexus_config" model="ir.actions.act_window">
        <field name="name">Configuración NEXUS</field>
        <field name="res_model">nexus.config</field>
        <field name="view_mode">form</field>
    </record>
</odoo>
